<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Нижний слой: тёмно-синяя обводка (скруглённый прямоугольник) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A2D47" />
            <corners android:radius="@dimen/card_radius" />
        </shape>
    </item>
    <!-- Верхний слой: белый фон с отступом, чтобы синий просвечивал по краям -->
    <item
        android:left="3dp"
        android:top="3dp"
        android:right="3dp"
        android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_light" />
            <corners android:radius="9dp" />
        </shape>
    </item>
</layer-list>

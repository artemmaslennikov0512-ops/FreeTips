{
  "name": "1tips",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "test": "tsx --test tests/validation/*.test.ts tests/security/*.test.ts tests/integration/*.test.ts",
    "test:coverage": "c8 --reporter=text --reports-dir=coverage --exclude=tests --exclude=**/*.config.* tsx --test tests/validation/*.test.ts tests/security/*.test.ts tests/integration/*.test.ts",
    "prepush": "npm run lint && npm run build && npm run test",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "copy-apk": "node -e \"const fs=require('fs'); const p='android/app/build/outputs/apk/debug/app-debug.apk'; const d='public/freetips.apk'; fs.copyFileSync(p,d); console.log('APK скопирован в public/freetips.apk');\""
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/client": "6.19.2",
    "bcryptjs": "^2.4.3",
    "ioredis": "^5.6.1",
    "jose": "^5.9.6",
    "lucide-react": "^0.460.0",
    "next": "16.1.6",
    "nodemailer": "^8.0.1",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "ws": "^8.19.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "playwright": "^1.49.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "c8": "^10.1.2",
    "dotenv": "^16.4.5",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "prisma": "6.19.2",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "5.9.3"
  }
}
